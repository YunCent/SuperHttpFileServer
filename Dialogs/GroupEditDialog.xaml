<Window x:Class="SuperHttpFileServer.GroupEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建分组" Height="300" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 分组名 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="分组名" Style="{StaticResource Label}"/>
            <TextBox Grid.Column="1" x:Name="GroupNameBox" Style="{StaticResource ModernInput}"/>
        </Grid>

        <!-- 共享目录 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="共享目录" Style="{StaticResource Label}"/>
            <TextBox Grid.Column="1" x:Name="ShareDirBox" Style="{StaticResource ModernInput}" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="浏览" Style="{StaticResource IconBtn}" Click="OnBrowseDir"/>
        </Grid>

        <!-- 权限 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <CheckBox x:Name="AllowDeleteCheck" Content="删除" Margin="0,0,12,0"/>
            <CheckBox x:Name="AllowUploadCheck" Content="上传" Margin="0,0,12,0"/>
            <CheckBox x:Name="AllowZipCheck" Content="压缩" Margin="0,0,12,0"/>
            <CheckBox x:Name="AllowMoveCheck" Content="移动" Margin="0,0,12,0"/>
            <CheckBox x:Name="AllowRenameCheck" Content="重命名"/>
        </StackPanel>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Style="{StaticResource ModernBtn}" Click="OnOk" Margin="0,0,8,0"/>
            <Button Content="取消" Style="{StaticResource GhostBtn}" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
