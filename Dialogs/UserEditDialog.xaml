<Window x:Class="SuperHttpFileServer.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建" Height="300" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 用户名 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="用户名" Style="{StaticResource Label}"/>
            <TextBox Grid.Column="1" x:Name="UsernameBox" Style="{StaticResource ModernInput}"/>
        </Grid>

        <!-- 密码 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="密码" Style="{StaticResource Label}"/>
            <Grid Grid.Column="1">
                <TextBox x:Name="PasswordTextBox" Style="{StaticResource ModernInput}" Padding="6,0,28,0"/>
                <Button x:Name="TogglePwdBtn" Content="👁" Width="24" Height="24"
                        FontSize="12" Padding="0" BorderThickness="0"
                        Background="Transparent" Cursor="Hand"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                        Click="OnTogglePwd"/>
            </Grid>
        </Grid>

        <!-- 分组 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="分组" Style="{StaticResource Label}"/>
            <ComboBox Grid.Column="1" x:Name="GroupComboBox" IsEditable="False" Height="32" FontSize="13"/>
        </Grid>

        <!-- 权限 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <CheckBox x:Name="AllowDeleteCheck" Content="删除" Margin="0,0,12,0"/>
            <CheckBox x:Name="AllowUploadCheck" Content="上传" Margin="0,0,12,0"/>
            <CheckBox x:Name="AllowZipCheck" Content="压缩" Margin="0,0,12,0"/>
            <CheckBox x:Name="AllowMoveCheck" Content="移动" Margin="0,0,12,0"/>
            <CheckBox x:Name="AllowRenameCheck" Content="重命名"/>
        </StackPanel>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Style="{StaticResource ModernBtn}" Click="OnOk" Margin="0,0,8,0"/>
            <Button Content="取消" Style="{StaticResource GhostBtn}" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
