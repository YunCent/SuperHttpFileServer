<Window x:Class="SuperHttpFileServer.LogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="运行日志" Height="360" Width="400"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" Background="#F5F5F5">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="LogBox" Grid.Row="0" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                 Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1"
                 Padding="8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="清空日志" Style="{StaticResource GhostBtn}" Click="OnClear" Margin="0,0,8,0"/>
            <Button Content="关闭" Style="{StaticResource ModernBtn}" Click="OnClose" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
