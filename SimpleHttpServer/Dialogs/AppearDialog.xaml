<Window x:Class="SimpleHttpServer.AppearDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="界面管理" Height="360" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA">

    <Grid Margin="14,8,14,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="0,0,0,4">
            <!-- 界面页签 -->
            <TabItem Header="界面">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="6,4">
                    <StackPanel Margin="0">
                        <!-- 网站标题 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="网站标题" Style="{StaticResource Label}"/>
                            <TextBox Grid.Column="1" x:Name="WebTitleBox" Style="{StaticResource ModernInput}"/>
                        </Grid>

                        <!-- 网站图标 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="网站图标" Style="{StaticResource Label}"/>
                            <TextBox Grid.Column="1" x:Name="FavIcoPathBox" Style="{StaticResource ModernInput}" Margin="0,0,6,0"
                                     IsReadOnly="True" Background="#F5F5F5"/>
                            <Button Grid.Column="2" Content="选择" Style="{StaticResource GhostBtn}" Click="OnBrowseFavIco"/>
                        </Grid>
                        <TextBlock Text="支持 ICO、PNG、JPG 格式" Style="{StaticResource HintText}" Margin="70,0,0,6"/>

                        <!-- Logo 图标 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Logo 图标" Style="{StaticResource Label}"/>
                            <TextBox Grid.Column="1" x:Name="IcoPathBox" Style="{StaticResource ModernInput}" Margin="0,0,6,0"
                                     IsReadOnly="True" Background="#F5F5F5"/>
                            <Button Grid.Column="2" Content="选择" Style="{StaticResource GhostBtn}" Click="OnBrowseIco"/>
                        </Grid>
                        <TextBlock Text="支持 ICO、PNG、JPG 格式" Style="{StaticResource HintText}" Margin="70,0,0,6"/>

                        <!-- 预览区 -->
                        <Border Background="#FFF" CornerRadius="6" Padding="12,6" Margin="0,0,0,0"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="预览效果" Style="{StaticResource StatusText}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="PreviewLogo" Width="24" Height="24" CornerRadius="6" Margin="0,0,8,0"
                                            BorderBrush="#E0E0E0" BorderThickness="1" ClipToBounds="True">
                                        <Image x:Name="PreviewLogoImg" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <TextBlock x:Name="PreviewTitle" Text="File Server" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#424242" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 证书页签 -->
            <TabItem Header="证书">
                <StackPanel Margin="6,4,6,6">
                    <!-- 备案信息 + 字号 同一行 -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="备案信息" Style="{StaticResource Label}"/>
                        <TextBox Grid.Column="1" x:Name="BeianBox" Style="{StaticResource ModernInput}" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="2" Text="字号" Style="{StaticResource HintText}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="3" x:Name="BeianSizeBox" Width="44" Height="26" FontSize="13" VerticalContentAlignment="Center"
                                 Margin="6,0,4,0" Text="15" PreviewTextInput="OnNumberOnly"/>
                        <TextBlock Grid.Column="4" Text="px" Style="{StaticResource HintText}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 启用 HTTPS -->
                    <CheckBox x:Name="SslEnabledCheck" Content="启用 HTTPS" Margin="0,0,0,8"
                              ToolTip="勾选后使用 SSL 证书加密连接"/>

                    <!-- 域名 -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="域名" Style="{StaticResource Label}"/>
                        <TextBox Grid.Column="1" x:Name="DomainBox" Style="{StaticResource ModernInput}"
                                 ToolTip="证书绑定的域名"/>
                    </Grid>

                    <!-- SSL 证书文件 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="证书文件" Style="{StaticResource Label}"/>
                        <TextBox Grid.Column="1" x:Name="CertPathBox" Style="{StaticResource ModernInput}" Margin="0,0,6,0"
                                 IsReadOnly="True" Background="#F5F5F5"
                                 ToolTip="Apache/Nginx 通用格式 .crt 或 .pem 文件"/>
                        <Button Grid.Column="2" Content="选择" Style="{StaticResource GhostBtn}" Click="OnBrowseCert"/>
                    </Grid>
                    <TextBlock Text="支持 CRT/PEM+KEY 或 PFX 文件" Style="{StaticResource HintText}" Margin="70,0,0,4"/>

                    <!-- SSL 密钥文件 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="密钥文件" Style="{StaticResource Label}"/>
                        <TextBox Grid.Column="1" x:Name="KeyPathBox" Style="{StaticResource ModernInput}" Margin="0,0,6,0"
                                 IsReadOnly="True" Background="#F5F5F5"
                                 ToolTip="Apache/Nginx 通用格式 .key 文件"/>
                        <Button Grid.Column="2" Content="选择" Style="{StaticResource GhostBtn}" Click="OnBrowseKey"/>
                    </Grid>

                    <!-- 证书状态 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="测试" FontSize="12" Height="26" Padding="10,0"
                                Style="{StaticResource GhostBtn}" Click="OnTestCert"/>
                        <TextBlock x:Name="CertStatusText" VerticalAlignment="Center" FontSize="12"
                                   Margin="10,0,0,0" Foreground="#999" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="重置" Style="{StaticResource GhostBtn}" Click="OnReset" Margin="0,0,8,0" MinWidth="60"/>
            <Button Content="确定" Style="{StaticResource ModernBtn}" Click="OnSave" Margin="0,0,8,0"/>
            <Button Content="取消" Style="{StaticResource GhostBtn}" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
