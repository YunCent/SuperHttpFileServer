<Window x:Class="SimpleHttpServer.PreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="预览管理" Height="360" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA">

    <Grid Margin="18,14,18,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView Grid.Row="0" x:Name="PluginListView" Margin="0,0,0,8"
                  BorderBrush="#E0E0E0" BorderThickness="1"
                  FontSize="13" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="启用" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="插件" Width="90" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="分类" Width="54" DisplayMemberBinding="{Binding Category}"/>
                    <GridViewColumn Header="支持格式" Width="170">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ExtText}" TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ExtText}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="全选" Style="{StaticResource GhostBtn}" Click="OnSelectAll" Margin="0,0,8,0"/>
            <Button Content="全不选" Style="{StaticResource GhostBtn}" Click="OnSelectNone" Margin="0,0,8,0"/>
            <Button Content="确定" Style="{StaticResource ModernBtn}" Click="OnOk" Margin="0,0,8,0"/>
            <Button Content="取消" Style="{StaticResource GhostBtn}" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
